{
  "name": "@k3_2o/pi-composio",
  "version": "0.2.1",
  "private": false,
  "description": "Pi extension — Composio integration for 1,000+ app tools",
  "keywords": [
    "pi-package",
    "extension",
    "composio",
    "tools",
    "integrations"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "fmt": "prettier --write 'index.ts' 'lib/**/*.ts'",
    "fmt:check": "prettier --check 'index.ts' 'lib/**/*.ts'",
    "lint": "eslint 'index.ts' 'lib/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "check": "npm run fmt:check && npm run lint && npm run typecheck",
    "security": "npm audit --audit-level=high",
    "ci": "npm run check && npm run security",
    "smoke": "node -e \"import('./index.ts')\""
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@composio/core": "0.13.0",
    "zod": "3.25.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
